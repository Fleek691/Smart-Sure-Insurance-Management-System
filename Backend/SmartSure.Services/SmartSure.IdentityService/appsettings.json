{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "AuthDb": "${AUTHDB_CONNECTION_STRING}"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "${JWT_ISSUER}",
    "Aud1": "${JWT_AUD1}",
    "Aud2": "${JWT_AUD2}",
    "Aud3": "${JWT_AUD3}",
    "Aud4": "${JWT_AUD4}",
    "Aud5": "${JWT_AUD5}"
  },
  "AdminSettings": {
    "Password": "${ADMIN_PASSWORD}"
  },
  "Google": {
    "ClientId": "${GOOGLE_CLIENT_ID}",
    "ClientSecret": "${GOOGLE_CLIENT_SECRET}",
    "RedirectUri": "${GOOGLE_REDIRECT_URI}",
    "FrontendCallbackUrl": "${GOOGLE_FRONTEND_CALLBACK_URL}"
  },
  "Email": {
    "SmtpHost": "${SMTP_HOST}",
    "SmtpPort": "${SMTP_PORT}",
    "SmtpUser": "${SMTP_USER}",
    "SmtpPass": "${SMTP_PASS}",
    "FromEmail": "${FROM_EMAIL}",
    "FromName": "${FROM_NAME}"
  },
  "RabbitMq": {
    "HostName": "${RABBITMQ_HOSTNAME}",
    "Port": "${RABBITMQ_PORT}",
    "UserName": "${RABBITMQ_USERNAME}",
    "Password": "${RABBITMQ_PASSWORD}",
    "VirtualHost": "${RABBITMQ_VHOST}",
    "ExchangeName": "${RABBITMQ_EXCHANGE}"
  },
  "AllowedHosts": "*"
}
