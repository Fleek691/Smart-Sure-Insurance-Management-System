{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "ClaimsDb": "${DB_CONNECTION_STRING}"
  },
  "Jwt": {
    "Key": "${JWT_SECRET}",
    "Issuer": "${JWT_ISSUER}",
    "Aud1": "${JWT_AUDIENCE1}",
    "Aud2": "${JWT_AUDIENCE2}",
    "Aud3": "${JWT_AUDIENCE3}",
    "Aud4": "${JWT_AUDIENCE4}",
    "Aud5": "${JWT_AUDIENCE5}"
  },
  "Mega": {
    "Email": "${MEGA_EMAIL}",
    "Password": "${MEGA_PASSWORD}"
  },
  "RabbitMq": {
    "HostName": "${RABBITMQ_HOST}",
    "Port": "${RABBITMQ_PORT}",
    "UserName": "${RABBITMQ_USER}",
    "Password": "${RABBITMQ_PASS}",
    "VirtualHost": "${RABBITMQ_VHOST}",
    "ExchangeName": "${RABBITMQ_EXCHANGE}"
  },
  "AllowedHosts": "*"
}
