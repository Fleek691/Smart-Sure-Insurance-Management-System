{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "AdminDb": "${ADMINDB_CONNECTION_STRING}"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "${JWT_ISSUER}",
    "Aud1": "${JWT_AUD1}",
    "Aud2": "${JWT_AUD2}",
    "Aud3": "${JWT_AUD3}",
    "Aud4": "${JWT_AUD4}",
    "Aud5": "${JWT_AUD5}"
  },
  "RabbitMq": {
    "HostName": "${RABBITMQ_HOSTNAME}",
    "Port": "${RABBITMQ_PORT}",
    "UserName": "${RABBITMQ_USERNAME}",
    "Password": "${RABBITMQ_PASSWORD}",
    "VirtualHost": "${RABBITMQ_VHOST}",
    "ExchangeName": "${RABBITMQ_EXCHANGE}"
  },
  "AllowedHosts": "*"
}
