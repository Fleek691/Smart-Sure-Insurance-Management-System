# .gitignore for Smart-Sure .NET + Angular monorepo

# Ignore build outputs
**/bin/
**/obj/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio
.vs/
.vscode/
*.slnLaunch.user

# HTTP test files (auto-generated boilerplate)
*.http

# Backend environment secrets — never commit .env files
Backend/**/.env
Backend/.env

# Logs
**/logs/
*.log

# Dependency directories
Backend/**/packages/
Backend/**/project.lock.json

# ASP.NET secrets
secrets.json

# Publish outputs
**/publish/
**/out/

# Node modules (Frontend)
Frontend/smartsure-ui/node_modules/

# Angular build outputs
Frontend/smartsure-ui/dist/

# Environment files
Frontend/smartsure-ui/.env
Frontend/smartsure-ui/.env.*

# OS files
.DS_Store
Thumbs.db

# Others
*.swp
*.tmp
*.bak
*.orig

# Rider
.idea/
*.sln.iml

# Temp / scratch files
.tmp_arch/
arch_doc.txt
project_doc.txt

# Uploaded claim documents (local fallback storage — not for source control)
Backend/SmartSure.Services/SmartSure.ClaimsService/uploads/

# Test results and coverage reports
Backend/SmartSure.Tests/TestResults/
